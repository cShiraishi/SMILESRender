# SmileRender — Environment Variables
# Copy this file to .env and adjust values for your setup.
# All variables are optional for local development.

# --- Server ---
PORT=3000
THREADS=4

# --- Admin Panel ---
# Prefix for the hidden admin route (e.g. /sradmin)
ADMIN_PREFIX=sradmin
ADMIN_PASS=changeme

# --- Redis / Celery (required for async batch jobs and docking) ---
REDIS_URL=redis://localhost:6379/0

# --- Feature Flags ---
# Set to 1 to skip loading ML models at startup (useful for lightweight dev)
SKIP_MODELS=0

# --- Analytics (optional) ---
# ANALYTICS_KEY=
