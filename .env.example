# SmileRender — Environment Variables
# Copy to .env and adjust for your setup.

# ── Chemistry service (Flask) ────────────────────────────────────────────────
PORT=3000
THREADS=4
SKIP_MODELS=0                     # 1 = skip loading ML models at startup

# ── Admin panel (legacy — will move to AdonisJS in Phase 2) ─────────────────
ADMIN_PREFIX=sradmin
ADMIN_PASS=changeme

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── REINVENT 4 — Molecular Generation ───────────────────────────────────────
# Option A (conda): set REINVENT_CONDA_ENV + run .\scripts\setup_reinvent.ps1
REINVENT_CONDA_ENV=libprep
# Option B (venv/pip): set REINVENT_PYTHON to the python.exe that has reinvent4
# REINVENT_PYTHON=C:/envs/reinvent/python.exe
# Model file (.prior) downloaded from huggingface.co/MolecularAI/reinvent4
REINVENT_MODEL_PATH=C:/models/reinvent/Mol2MolVS_v1.prior

# ── API gateway (NestJS) ─────────────────────────────────────────────────────
# CHEMISTRY_URL is set automatically by docker-compose via service name.
# Only set this manually for local dev outside Docker.
# CHEMISTRY_URL=http://localhost:3000

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password
# DATABASE_URL is built automatically by docker-compose.
# Only set manually for local dev outside Docker:
# DATABASE_URL=postgresql://smilerender:change-me@localhost:5432/smilerender

# ── Admin API (AdonisJS) ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_APP_KEY=change-me-to-a-32-char-random-string

# ── Admin credentials (used only by db-seed on first boot) ───────────────────
ADMIN_EMAIL=admin@smilesrender.com
ADMIN_PASSWORD=change-me-strong-password
